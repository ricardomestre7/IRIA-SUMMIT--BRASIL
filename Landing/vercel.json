{
  "version": 2,
  "installCommand": "composer install --no-dev --no-scripts --optimize-autoloader --ignore-platform-reqs",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/(.*\\.(css|js|mjs|webp|png|jpg|jpeg|svg|gif|ico|woff2?|ttf|eot|map|mp4|webm))$", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
