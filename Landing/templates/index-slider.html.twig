{% extends 'partials/layouts/master.html.twig' %}

{% block page_contents %}

        <section id="section-hero" class="section-dark text-light no-top no-bottom relative overflow-hidden z-1000">
            <div class="abs abs-centered z-2 w-80">
                <div class="container wow scaleIn" data-wow-duration="3s">
                    <div class="row justify-content-center">
                        <div class="col-lg-12 text-center">
                            <div class="subtitle">Inteligência · Regeneração · Inclusão · Ação</div>
                            <h1 class="fs-72 text-uppercase fs-sm-12vw mb-3 lh-1">IRIA SUMMIT PORTUGAL 2026</h1>
                            <p class="fs-16 op-8 mb-4 col-xl-8 mx-auto">Um ecossistema vivo de territórios, instituições e empresas — Ovar, Santa Maria da Feira e Aveiro em sequência, com a mesma visão estratégica.</p>

                            <div class="d-block d-md-flex justify-content-center">
                                <div class="d-flex justify-content-center align-items-center mx-4">
                                    <i class="fa fa-calendar id-color me-3"></i>
                                    <h4 class="mb-0">Ciclo 2026 · Ovar · Feira · Aveiro</h4>
                                </div>

                                <div class="d-flex justify-content-center align-items-center mx-4">
                                    <i class="fa fa-location-pin id-color me-3"></i>
                                    <h4 class="mb-0">1.ª fase: 18–19 jun · Ovar</h4>
                                </div>
                            </div>

                            <div class="spacer-single"></div>

                            <a class="btn-main mx-2 fx-slide" href="#section-tickets"><span>Bilhetes</span></a>
                            <a class="btn-main btn-line mx-2 fx-slide" href="#section-schedule"><span>Programa-tipo</span></a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="mh-800">
                <div class="swiper">
                  <!-- Additional required wrapper -->
                  <div class="swiper-wrapper">
                    <!-- Slides -->
                    <div class="swiper-slide">
                        <div class="swiper-inner" data-bgimage="url(assets/images/slider/1.webp)">
                            <div class="sw-overlay op-6"></div>
                            <div class="gradient-edge-bottom"></div>
                        </div>
                    </div>

                    <!-- Slides -->
                    <div class="swiper-slide">
                        <div class="swiper-inner" data-bgimage="url(assets/images/slider/2.webp)">
                            <div class="sw-overlay op-6"></div>
                            <div class="gradient-edge-bottom"></div>
                        </div>
                    </div>


                  </div>
                  <!-- If we need pagination -->
                  <div class="swiper-pagination"></div>

                  <!-- If we need navigation buttons -->
                  <div class="swiper-button-prev"></div>
                  <div class="swiper-button-next"></div>
                </div>
            </div>
        </section>

        <section id="section-about" class="bg-dark section-dark text-light">
            <div class="container">
                <div class="row  gx-5 align-items-center">
                    <div class="col-lg-6">
                          <div class="me-lg-5 pe-lg-5 py-5 my-5">
                              <div class="subtitle wow fadeInUp" data-wow-delay=".2s">1. Enquadramento geral</div>
                              <h2 class="wow fadeInUp" data-wow-delay=".4s">Plataforma portuguesa com vocação de continuidade</h2>
                              <p class="wow fadeInUp" data-wow-delay=".6s">O IRIA SUMMIT PORTUGAL é uma plataforma de encontro, articulação e aplicação prática da inteligência artificial numa perspetiva inclusiva, regenerativa, territorial e estrategicamente orientada. Não se limita à lógica de um congresso convencional: liga tecnologia, governação, saúde, educação, empresas, inovação aplicada e desenvolvimento humano.</p>

                              <ul class="ul-check">
                                  <li class="wow fadeInUp" data-wow-delay=".8s">Ovar — origem, validação e legitimidade inicial</li>
                                  <li class="wow fadeInUp" data-wow-delay=".9s">Santa Maria da Feira — consolidação e expansão regional</li>
                                  <li class="wow fadeInUp" data-wow-delay="1s">Aveiro — projeção, autoridade e escala superior</li>
                              </ul>

                          </div>
                    </div>

                    <div class="col-lg-6">
                        <div class="row g-4">
                            <div class="col-6">
                                <div class="relative overflow-hidden rounded-1 wow scale-in-mask mb-4">
                                    <img src="assets/images/misc/s1.webp" class="img-fluid" alt="">
                                    <div class="gradient-edge-bottom h-50"></div>
                                </div>
                                <div class="col-12 text-center">
                                    <div class="bg-color text-light p-30 rounded-1 wow scale-in-mask">
                                        <div class="de_count">
                                            <h2 class="mb-0"><span class="timer" data-to="3" data-speed="2000"></span></h2>
                                            <div>Cidades anfitriãs</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="spacer-double sm-hide"></div>
                                <div class="col-12 text-center">
                                    <div class="bg-color-2 text-light p-30 rounded-1 wow scale-in-mask">
                                        <div class="de_count">
                                            <h2 class="mb-0"><span class="timer" data-to="4" data-speed="2000"></span></h2>
                                            <div>Dias por edição (modelo)</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="relative overflow-hidden rounded-1 wow scale-in-mask mt-4">
                                    <img src="assets/images/misc/s2.webp" class="img-fluid" alt="">
                                    <div class="gradient-edge-bottom h-50"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        {% include 'partials/marquee-bands-iria.html.twig' %}

        {% include 'partials/section-summit-delivers-iria.html.twig' %}

        <section class="bg-dark section-dark text-light pt-80 relative jarallax" aria-label="section">
            <img src="assets/images/background/2.webp" class="jarallax-img" alt="">
            <div class="gradient-edge-top"></div>
            <div class="gradient-edge-bottom"></div>
            <div class="sw-overlay op-8"></div>
            <div class="container relative z-4">
