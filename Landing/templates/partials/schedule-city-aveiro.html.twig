{% import 'partials/_schedule-macros.html.twig' as sch %}
<div>
    <div class="text-center mb-4 pb-4 border-white-bottom-op-2">
        <h3 class="fs-28 mb-2">IRIA SUMMIT PORTUGAL — AVEIRO</h3>
        <p class="subtitle s2 mb-2">Fase 03 | Árvore</p>
        <p class="fs-14 op-7 mb-1">Programa Base — Datas a confirmar</p>
        <p class="fs-13 op-6 mb-0">Datas e oradores a confirmar.</p>
    </div>
    <div class="de-tab plain">
        <ul class="d-tab-nav mb-4 pb-4 d-flex flex-wrap justify-content-lg-between justify-content-center gap-3">
            <li class="active-tab"><h3 class="fs-18 mb-0">Dia 1</h3><span class="fs-13 op-7">Presencial</span></li>
            <li><h3 class="fs-18 mb-0">Dia 2</h3><span class="fs-13 op-7">Presencial</span></li>
            <li><h3 class="fs-18 mb-0">Dia 3</h3><span class="fs-13 op-7">Online</span></li>
            <li><h3 class="fs-18 mb-0">Dia 4</h3><span class="fs-13 op-7">Online</span></li>
        </ul>
        <ul class="d-tab-content pt-3">
            <li>
                <p class="subtitle s2 mb-1">Dia 1 — Presencial</p>
                <h3 class="fs-22 mb-4">Projeção, Ciência e Autoridade</h3>
                {{ sch.sess('Abertura Institucional da Fase 03', 'Sessão de abertura da edição de Aveiro, posicionando o summit como plataforma de projeção nacional e europeia.') }}
                {{ sch.sess('Conferência Âncora — O futuro da inteligência artificial em Portugal e na Europa', 'Visão estratégica sobre inovação, regulação, competitividade, saúde, educação e soberania digital.') }}
                {{ sch.sess('Painel — Ciência, academia e transferência de conhecimento', 'Debate sobre investigação, universidades, centros de conhecimento e aplicação de IA em contexto real.') }}
                {{ sch.sess('Mesa Redonda — IA, instituições e transformação sistémica', 'Discussão sobre o papel da inteligência artificial na reconfiguração de organizações, serviços e modelos de decisão.') }}
            </li>
            <li>
                <p class="subtitle s2 mb-1">Dia 2 — Presencial</p>
                <h3 class="fs-22 mb-4">Demonstração, Cooperação e Escala</h3>
                {{ sch.sess('Workshop — IA em contexto avançado de aplicação', 'Sessão dedicada a soluções, plataformas, integração e casos de uso com maior densidade estratégica.') }}
                {{ sch.sess('Painel — Ética, regulação e confiança pública', 'Debate sobre governação, AI Act, responsabilidade, transparência e alinhamento europeu.') }}
                {{ sch.sess('Showcase — Projetos, soluções e alianças de futuro', 'Momento de apresentação de iniciativas com potencial de escala, cooperação e continuidade.', 'Oradores e projetos: a confirmar') }}
                {{ sch.sess('Encerramento Presencial do Ciclo 2026', 'Síntese institucional da fase Aveiro e consolidação da visão do IRIA SUMMIT PORTUGAL.') }}
            </li>
            <li>
                <p class="subtitle s2 mb-1">Dia 3 — Online</p>
                <h3 class="fs-22 mb-4">Fórum Global e Perspetiva Europeia</h3>
                {{ sch.sess('Abertura Online da Fase 03', 'Ligação da edição de Aveiro a uma audiência mais ampla, nacional e internacional.') }}
                {{ sch.sess('Conferência Internacional — IA, Europa e futuro aplicado', 'Reflexão sobre o lugar de Portugal nos ecossistemas emergentes de inteligência artificial e inovação responsável.') }}
                {{ sch.sess('Debate Alargado — Regulação, escala e impacto', 'Sessão participativa sobre os grandes temas do presente e do futuro da IA.') }}
            </li>
            <li>
                <p class="subtitle s2 mb-1">Dia 4 — Online</p>
                <h3 class="fs-22 mb-4">Síntese, Legado e Continuidade</h3>
                {{ sch.sess('Síntese Geral do Ciclo 2026', 'Resumo das três fases do summit e consolidação da leitura estratégica do percurso.') }}
                {{ sch.sess('Sessão Final — Continuidade, expansão e próximos passos', 'Apresentação das perspetivas futuras do projeto, alianças e caminhos de evolução.') }}
                {{ sch.sess('Encerramento Oficial do IRIA SUMMIT PORTUGAL 2026', 'Mensagem final de fecho do ciclo e afirmação do summit como plataforma com continuidade.') }}
            </li>
        </ul>
    </div>
</div>
