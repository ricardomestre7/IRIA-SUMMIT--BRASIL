{% import 'partials/_schedule-macros.html.twig' as sch %}
<div>
    <div class="text-center mb-4 pb-4 border-white-bottom-op-2">
        <h3 class="fs-28 mb-2">IRIA SUMMIT PORTUGAL — OVAR</h3>
        <p class="subtitle s2 mb-2">Fase 01 | Semente</p>
        <p class="fs-14 op-7 mb-1">Programa Base — Datas a confirmar</p>
        <p class="fs-13 op-6 mb-0">Datas e oradores a confirmar.</p>
    </div>
    <div class="de-tab plain">
        <ul class="d-tab-nav mb-4 pb-4 d-flex flex-wrap justify-content-lg-between justify-content-center gap-3">
            <li class="active-tab"><h3 class="fs-18 mb-0">Dia 1</h3><span class="fs-13 op-7">Presencial</span></li>
            <li><h3 class="fs-18 mb-0">Dia 2</h3><span class="fs-13 op-7">Presencial</span></li>
            <li><h3 class="fs-18 mb-0">Dia 3</h3><span class="fs-13 op-7">Online</span></li>
            <li><h3 class="fs-18 mb-0">Dia 4</h3><span class="fs-13 op-7">Online</span></li>
        </ul>
        <ul class="d-tab-content pt-3">
            <li>
                <p class="subtitle s2 mb-1">Dia 1 — Presencial</p>
                <h3 class="fs-22 mb-4">Território e Diagnóstico</h3>
                {{ sch.sess('Sessão de Abertura Institucional', 'Abertura oficial da edição de Ovar com enquadramento institucional, visão do summit e apresentação da proposta territorial da Fase 01.') }}
                {{ sch.sess('Conferência Âncora — IA Inclusiva: o que Portugal precisa compreender agora', 'Uma leitura estratégica sobre o papel da inteligência artificial no presente e no futuro próximo, com foco em inclusão, aplicação e impacto humano.') }}
                {{ sch.sess('Painel — IA, Saúde e Regeneração', 'Debate sobre aplicações da inteligência artificial na saúde, bem-estar, prevenção, apoio clínico e novas abordagens regenerativas.') }}
                {{ sch.sess('Mesa Redonda — O território como laboratório vivo de inovação', 'Reflexão sobre como municípios, instituições locais e agentes regionais podem integrar IA de forma útil e realista.') }}
            </li>
            <li>
                <p class="subtitle s2 mb-1">Dia 2 — Presencial</p>
                <h3 class="fs-22 mb-4">Aplicação e Futuro</h3>
                {{ sch.sess('Workshop — IA para profissionais, negócios e instituições', 'Sessão prática orientada para aplicações reais da inteligência artificial em contexto empresarial, institucional e profissional.') }}
                {{ sch.sess('Painel — Ética, Consciência e Direção da IA', 'Debate sobre responsabilidade, confiança, regulação, impacto social e a necessidade de uma inteligência artificial humanamente orientada.') }}
                {{ sch.sess('Apresentação de Projetos e Casos de Uso', 'Espaço dedicado à demonstração de soluções, plataformas e iniciativas com aplicação concreta.', 'Oradores e projetos: a confirmar') }}
                {{ sch.sess('Sessão de Encerramento Presencial', 'Síntese da edição de Ovar e projeção da etapa seguinte do IRIA SUMMIT PORTUGAL.') }}
            </li>
            <li>
                <p class="subtitle s2 mb-1">Dia 3 — Online</p>
                <h3 class="fs-22 mb-4">Fórum Alargado</h3>
                {{ sch.sess('Abertura Digital da Edição', 'Mensagem de receção ao público online e enquadramento dos temas centrais do fórum digital.') }}
                {{ sch.sess('Conferência Online — IA, sociedade e transformação em escala', 'Uma visão ampliada sobre o impacto da IA nos sistemas sociais, institucionais e económicos.') }}
                {{ sch.sess('Debate Aberto — Perguntas do público e perspetivas multissetoriais', 'Sessão participativa com perguntas, respostas e interação com especialistas convidados.') }}
            </li>
            <li>
                <p class="subtitle s2 mb-1">Dia 4 — Online</p>
                <h3 class="fs-22 mb-4">Síntese e Continuidade</h3>
                {{ sch.sess('Resumo Estratégico da Edição', 'Síntese dos principais temas, ideias e caminhos emergentes da edição de Ovar.') }}
                {{ sch.sess('Workshop Aberto — Aplicações práticas da IA no quotidiano profissional', 'Sessão orientada para ferramentas, utilidade concreta e adoção progressiva.') }}
                {{ sch.sess('Encerramento Oficial da Fase 01', 'Mensagem final e ligação à próxima etapa do summit.') }}
            </li>
        </ul>
    </div>
</div>
