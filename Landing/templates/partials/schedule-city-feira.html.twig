{% import 'partials/_schedule-macros.html.twig' as sch %}
<div>
    <div class="text-center mb-4 pb-4 border-white-bottom-op-2">
        <h3 class="fs-28 mb-2">IRIA SUMMIT PORTUGAL — SANTA MARIA DA FEIRA</h3>
        <p class="subtitle s2 mb-2">Fase 02 | Raiz</p>
        <p class="fs-14 op-7 mb-1">Programa Base — Datas a confirmar</p>
        <p class="fs-13 op-6 mb-0">Datas e oradores a confirmar.</p>
    </div>
    <div class="de-tab plain">
        <ul class="d-tab-nav mb-4 pb-4 d-flex flex-wrap justify-content-lg-between justify-content-center gap-3">
            <li class="active-tab"><h3 class="fs-18 mb-0">Dia 1</h3><span class="fs-13 op-7">Presencial</span></li>
            <li><h3 class="fs-18 mb-0">Dia 2</h3><span class="fs-13 op-7">Presencial</span></li>
            <li><h3 class="fs-18 mb-0">Dia 3</h3><span class="fs-13 op-7">Online</span></li>
            <li><h3 class="fs-18 mb-0">Dia 4</h3><span class="fs-13 op-7">Online</span></li>
        </ul>
        <ul class="d-tab-content pt-3">
            <li>
                <p class="subtitle s2 mb-1">Dia 1 — Presencial</p>
                <h3 class="fs-22 mb-4">Escala, Território e Expansão</h3>
                {{ sch.sess('Sessão de Abertura Institucional', 'Abertura oficial da edição regional, com foco na consolidação do projeto e no seu crescimento em escala.') }}
                {{ sch.sess('Conferência Âncora — IA e transformação regional', 'Reflexão sobre o papel da IA na economia, nas organizações, nas cidades e na competitividade territorial.') }}
                {{ sch.sess('Painel — Empresas, inovação e futuro produtivo', 'Debate com enfoque em PMEs, digitalização, automação, competitividade e novas formas de criação de valor.') }}
                {{ sch.sess('Mesa Redonda — Ecossistemas regionais de inovação', 'Discussão sobre cooperação entre empresas, municípios, academia, financiadores e estruturas de apoio.') }}
            </li>
            <li>
                <p class="subtitle s2 mb-1">Dia 2 — Presencial</p>
                <h3 class="fs-22 mb-4">Capacitação, Aplicação e Articulação</h3>
                {{ sch.sess('Workshop — IA aplicada a empresas e instituições', 'Sessão prática orientada para adoção de IA, produtividade, decisão e integração em organizações.') }}
                {{ sch.sess('Painel — Educação, competências e novos perfis profissionais', 'Discussão sobre capacitação, reskilling, literacia digital e competências para o novo ciclo tecnológico.') }}
                {{ sch.sess('Apresentação de Projetos, Plataformas e Soluções', 'Espaço de demonstração para iniciativas com impacto empresarial, institucional e territorial.', 'Oradores e projetos: a confirmar') }}
                {{ sch.sess('Encerramento Presencial da Fase 02', 'Síntese dos resultados e projeção estratégica para a edição de Aveiro.') }}
            </li>
            <li>
                <p class="subtitle s2 mb-1">Dia 3 — Online</p>
                <h3 class="fs-22 mb-4">Fórum de Escala e Cooperação</h3>
                {{ sch.sess('Abertura Online', 'Mensagem de enquadramento da fase regional e ligação ao público digital alargado.') }}
                {{ sch.sess('Conferência Internacional — IA, competitividade e redes colaborativas', 'Reflexão sobre tendências internacionais e desafios de adoção em escala.') }}
                {{ sch.sess('Debate Aberto — IA, economia e sociedade', 'Sessão de perguntas e respostas com especialistas convidados e participação do público.') }}
            </li>
            <li>
                <p class="subtitle s2 mb-1">Dia 4 — Online</p>
                <h3 class="fs-22 mb-4">Síntese, Instrumentos e Próximo Passo</h3>
                {{ sch.sess('Síntese da Edição Regional', 'Resumo dos principais pontos programáticos e estratégicos da fase da Feira.') }}
                {{ sch.sess('Sessão Especial — Programas, financiamento e oportunidades', 'Espaço dedicado a instrumentos de inovação, financiamento e transformação digital.') }}
                {{ sch.sess('Encerramento Oficial da Fase 02', 'Mensagem de conclusão e passagem simbólica para Aveiro.') }}
