{% extends 'partials/layouts/master.html.twig' %}

{% block page_contents %}

        <section id="section-hero" class="section-dark no-top no-bottom text-light jarallax relative mh-800" data-video-src="mp4:assets/video/2.mp4">
            <div class="gradient-edge-top op-6 h-50 color"></div>
            <div class="gradient-edge-bottom"></div>
            <div class="sw-overlay op-8"></div>
            <div class="abs abs-centered z-2 w-80">
                <div class="container wow scaleIn" data-wow-duration="3s">
                    <div class="row">
                        <div class="col-lg-12 text-center">
                            <h1 class="fs-120 text-uppercase fs-sm-12vw mb-4 lh-1">IRIA SUMMIT BRASIL 2026</h1>
                            <p class="fs-28 fs-sm-8 wow fadeInUp mb-5 fw-bold op-9">Inovação Aplicada · Ciência · Consciência · Escala</p>

                            <div class="d-block d-md-flex justify-content-center mt-2">
                                <div class="d-flex justify-content-center align-items-center mx-4">
                                    <i class="fa fa-calendar id-color me-3"></i>
                                    <h4 class="mb-0">Ciclo 2026 · Curitiba · Porto Alegre · Salvador</h4>
                                </div>

                                <div class="d-flex justify-content-center align-items-center mx-4">
                                    <i class="fa fa-location-pin id-color me-3"></i>
                                    <h4 class="mb-0">1.ª fase: 19–21 set · Curitiba</h4>
                                </div>
                            </div>

                            <div class="spacer-single"></div>

                            <a class="btn-main mx-2 fx-slide" href="#section-tickets"><span>Garantir lugar</span></a>
                            <a class="btn-main btn-line mx-2 fx-slide" href="#section-phase-curitiba"><span>Programa Curitiba</span></a>
                            <a class="btn-main btn-line mx-2 fx-slide" href="#section-phase-poa"><span>Programa POA</span></a>
                            <a class="btn-main btn-line mx-2 fx-slide" href="#section-phase-salvador"><span>Programa Salvador</span></a>
                            <a class="btn-main btn-line mx-2 fx-slide" href="#section-schedule"><span>Resumos</span></a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="abs w-100 start-0 bottom-0 z-3">
                <div class="container">
                    <div class="sm-hide border-white-op-3 p-40 py-4 rounded-1 bg-blur relative overflow-hidden wow fadeInUp">
                        <div class="gradient-edge-bottom color start-0 h-50 op-5"></div>
                        <div class="row g-4 justify-content-between align-items-center relative z-2">
                            <div class="col-lg-3">
                                <h2 class="mb-0">Fase 01 — Curitiba</h2>
                                <h4 class="mb-0">Contagem para 19 de setembro de 2026</h4>
                            </div>
                            <div class="col-lg-4">
                                <div id="defaultCountdown" class="pt-2"></div>
                            </div>
                            <div class="col-lg-4">
                                <div class="d-flex">
                                    <i class="fs-60 icofont-google-map id-color"></i>
                                    <div class="ms-3">
                                        <h4 class="mb-0">CylinderMargin LDA<br>Curitiba, Brasil · 2026</h4>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section id="section-about" class="bg-dark section-dark text-light pt-120 pb-120">
            <div class="container">
                <div class="row gx-5 align-items-center justify-content-between">
                    <div class="col-lg-6 wow fadeInUp">
                        <div class="me-lg-4">
                            <div class="subtitle wow fadeInUp" data-wow-delay=".2s">1. Enquadramento geral</div>
                            <h2 class="wow fadeInUp" data-wow-delay=".4s">Plataforma brasileira de saúde, tecnologia e consciência aplicada</h2>
                            <p class="wow fadeInUp" data-wow-delay=".6s">O IRIA Summit Brasil não é um evento. É onde o futuro da saúde, da tecnologia e da consciência começa a ser aplicado na prática.</p>
                            <p class="wow fadeInUp" data-wow-delay=".65s">Organizado como um ciclo progressivo de três fases, o IRIA liga conhecimento, empresas, instituições, ciência, educação, saúde e decisão estratégica, afirmando um modelo de continuidade que ultrapassa a lógica de um evento isolado.</p>
                            <ul class="ul-check">
                                <li class="wow fadeInUp" data-wow-delay=".8s">Curitiba — inovação aplicada e laboratório vivo</li>
                                <li class="wow fadeInUp" data-wow-delay=".9s">Porto Alegre — ciência, mercado e escala</li>
                                <li class="wow fadeInUp" data-wow-delay="1s">Salvador — consciência, bem-estar e futuro humano</li>
                            </ul>
                        </div>
                    </div>

                    <div class="col-lg-5 wow scaleIn text-center">
                        <img src="assets/images/misc/c1.webp" class="w-100 rotate-animation" alt="">
                    </div>

                </div>
            </div>
        </section>


        {% include 'partials/marquee-bands-iria.html.twig' %}

        {% include 'partials/section-summit-delivers-iria.html.twig' %}
        <section id="section-speakers" class="bg-dark section-dark text-light pt-120 pb-120">
            <div class="container">
                <div class="row g-4 justify-content-center">
                    <div class="col-lg-10 relative z-3">
                          <div class="text-center">
                              <div class="subtitle wow fadeInUp" data-wow-delay=".0s">Oradores</div>
                              <h2 class="wow fadeInUp" data-wow-delay=".2s">Oradores e Convidados Estratégicos</h2>
                              <p class="lead wow fadeInUp mb-3">O painel do IRIA SUMMIT BRASIL está a ser construído em articulação com parceiros, instituições, empresas, academia e convidados de referência, de forma progressiva e alinhada com a identidade de cada fase do ciclo.</p>
                              <p class="wow fadeInUp op-9 mb-3">Mais do que reunir nomes, o IRIA procura construir um painel com relevância prática, densidade institucional e diversidade de perspetivas, cruzando inteligência artificial, território, inovação, capacitação, ciência, desenvolvimento económico e transformação aplicada.</p>
                              <p class="wow fadeInUp op-9 mb-0">Os primeiros anúncios serão feitos por fase, à medida que as confirmações forem formalizadas.</p>
                          </div>
                    </div>
                </div>

                <div class="row g-4 align-items-stretch mt-3 mt-lg-4">
                    <div class="col-lg-4">
                        <div class="hover relative rounded-1 overflow-hidden wow fadeIn scale-in-mask w-100" style="min-height: 480px;">
                            <img src="assets/images/speakers/painel-principal.webp" class="position-absolute top-0 start-0 w-100 h-100 hover-scale-1-1 op-4" alt="Conferência e painel de oradores" style="object-fit: cover;">
                            <div class="abs w-100 h-100 start-0 top-0 hover-op-1 radial-gradient-color"></div>
                            <div class="abs w-100 start-0 bottom-0 z-3">
                                <div class="bg-blur p-4 m-4 rounded-1 text-light relative z-2">
                                    <h3 class="mb-2 fs-22">Painel Principal</h3>
                                    <p class="mb-0 fs-14 op-9 lh-1-6" style="white-space: normal;">Intervenções centrais com líderes, especialistas, decisores e convidados com contributo estratégico para o posicionamento do summit.</p>
                                </div>
                                <div class="gradient-edge-bottom h-100 op-8"></div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="hover relative rounded-1 overflow-hidden wow fadeIn scale-in-mask w-100" style="min-height: 480px;">
                            <img src="assets/images/speakers/curadoria-fases.webp" class="position-absolute top-0 start-0 w-100 h-100 hover-scale-1-1 op-4" alt="Cidades e território — curadoria por fase" style="object-fit: cover;">
                            <div class="abs w-100 h-100 start-0 top-0 hover-op-1 radial-gradient-color"></div>
                            <div class="abs w-100 start-0 bottom-0 z-3">
                                <div class="bg-blur p-4 m-4 rounded-1 text-light relative z-2">
                                    <h3 class="mb-2 fs-22">Curadoria por Fase</h3>
                                    <p class="mb-0 fs-14 op-9 lh-1-6" style="white-space: normal;">Cada cidade contará com convidados alinhados com o seu eixo temático: ativação em Curitiba, expansão em Porto Alegre e consolidação em Salvador.</p>
                                </div>
                                <div class="gradient-edge-bottom h-100 op-8"></div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="hover relative rounded-1 overflow-hidden wow fadeIn scale-in-mask w-100" style="min-height: 480px;">
                            <img src="assets/images/speakers/anuncios-atualizacao.webp" class="position-absolute top-0 start-0 w-100 h-100 hover-scale-1-1 op-4" alt="Planeamento e calendário de anúncios" style="object-fit: cover;">
                            <div class="abs w-100 h-100 start-0 top-0 hover-op-1 radial-gradient-color"></div>
                            <div class="abs w-100 start-0 bottom-0 z-3">
                                <div class="bg-blur p-4 m-4 rounded-1 text-light relative z-2">
                                    <h3 class="mb-2 fs-22">Anúncios em Atualização</h3>
                                    <p class="mb-0 fs-14 op-9 lh-1-6" style="white-space: normal;">A programação de oradores e convidados será divulgada progressivamente, acompanhando a consolidação das parcerias e das confirmações institucionais.</p>
                                </div>
                                <div class="gradient-edge-bottom h-100 op-8"></div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <section class="bg-dark section-dark pt-120 pb-120 relative jarallax" aria-label="section">
            <img src="assets/images/background/1.webp" class="jarallax-img" alt="">
