{% extends 'partials/layouts/master.html.twig' %}

{% block page_contents %}

        <section id="section-hero" class="section-dark text-light p-0 relative overflow-hidden z-1000">
            <div class="mh-800">
                <div class="swiper">
                  <!-- Additional required wrapper -->
                  <div class="swiper-wrapper">
                    <!-- Slides -->
                    <div class="swiper-slide">
                        <div class="abs abs-centered z-2 w-100">
                            <div class="container" data-wow-duration="1s">
                                <div class="row">
                                    <div class="col-lg-7">
                                        <div class="subtitle">Inteligência · Regeneração · Inclusão · Ação</div>
                                        <h1 class="mb-3 uppercase">IRIA SUMMIT PORTUGAL 2026</h1>
                                        <p class="fs-15 op-8 mb-4">Ecossistema em movimento: três territórios, três momentos do mesmo percurso — da semente à raiz e à árvore.</p>

                                        <div class="d-block d-md-flex">
                                            <div class="d-flex align-items-center me-4">
                                                <i class="fa fa-calendar id-color me-3"></i>
                                                <h4 class="mb-0">Ciclo 2026 · Ovar · Feira · Aveiro</h4>
                                            </div>

                                            <div class="d-flex align-items-center me-4">
                                                <i class="fa fa-location-pin id-color me-3"></i>
                                                <h4 class="mb-0">1.ª fase: 1–3 jun · Ovar</h4>
                                            </div>
                                        </div>

                                        <div class="spacer-single"></div>

                                        <a class="btn-main mx-2 fx-slide" href="#section-tickets"><span>Bilhetes</span></a>
                                        <a class="btn-main btn-line mx-2 fx-slide" href="#section-phase-ovar"><span>Programa Ovar</span></a>
                                        <a class="btn-main btn-line mx-2 fx-slide" href="#section-phase-feira"><span>Programa Feira</span></a>
                                        <a class="btn-main btn-line mx-2 fx-slide" href="#section-phase-aveiro"><span>Programa Aveiro</span></a>
                                        <a class="btn-main btn-line mx-2 fx-slide" href="#section-schedule"><span>Resumos</span></a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="swiper-inner" data-bgimage="url(assets/images/slider/3.webp)">
                            <div class="sw-overlay op-3"></div>
                            <div class="gradient-edge-bottom"></div>
                        </div>
                    </div>

                    <!-- Slides -->
                    <div class="swiper-slide">
                        <div class="abs abs-centered z-2 w-100">
                            <div class="container" data-wow-duration="1s">
                                <div class="row">
                                    <div class="col-lg-7">
                                        <div class="subtitle">Ecossistema IRIA</div>
                                        <h1 class="mb-3 uppercase">Instituições, empresas e território na mesma conversa</h1>
                                        <p class="fs-15 op-8 mb-4">O summit reúne decisores, equipas técnicas e comunidades — com continuidade entre edições e canais oficiais de informação.</p>

                                        <div class="d-block d-md-flex">
                                            <div class="d-flex align-items-center me-4">
                                                <i class="fa fa-calendar id-color me-3"></i>
                                                <h4 class="mb-0">Jun · Set · Nov 2026</h4>
                                            </div>

                                            <div class="d-flex align-items-center me-4">
                                                <i class="fa fa-location-pin id-color me-3"></i>
                                                <h4 class="mb-0">Portugal · Centro e litoral</h4>
                                            </div>
                                        </div>

                                        <div class="spacer-single"></div>

                                        <a class="btn-main mx-2 fx-slide" href="#section-tickets"><span>Bilhetes</span></a>
                                        <a class="btn-main btn-line mx-2 fx-slide" href="#section-phase-ovar"><span>Programa Ovar</span></a>
                                        <a class="btn-main btn-line mx-2 fx-slide" href="#section-phase-feira"><span>Programa Feira</span></a>
                                        <a class="btn-main btn-line mx-2 fx-slide" href="#section-phase-aveiro"><span>Programa Aveiro</span></a>
                                        <a class="btn-main btn-line mx-2 fx-slide" href="#section-schedule"><span>Resumos</span></a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="swiper-inner" data-bgimage="url(assets/images/slider/4.webp)">
                            <div class="sw-overlay op-3"></div>
                            <div class="gradient-edge-bottom"></div>
                        </div>
                    </div>


                  </div>
                  <!-- If we need pagination -->
                  <div class="swiper-pagination"></div>

                  <!-- If we need navigation buttons -->
                  <div class="swiper-button-prev"></div>
                  <div class="swiper-button-next"></div>
                </div>
            </div>
