{% extends 'partials/layouts/master.html.twig' %}

{% block page_contents %}

        <section id="section-hero" class="section-dark no-top no-bottom text-light jarallax relative mh-800 jarallax">
            <img src="assets/images/background/5.webp" class="jarallax-img" alt="">
            <div class="gradient-edge-bottom h-50"></div>
            <div class="sw-overlay op-5"></div>
            <div class="abs w-80 bottom-10 z-2 w-100">
                <div class="container">
                    <div class="row">
                        <div class="col-lg-12">
                            <div class="relative wow mask-right">
                                <div class="text-start">
                                    <h1 class="fs-130 text-uppercase fs-sm-10vw mb-0 lh-1">Três cidades</h1>
                                </div>

                                <div class="text-lg-end">
                                    <h1 class="fs-130 text-uppercase fs-sm-10vw mb-4 lh-1">Uma visão</h1>
                                </div>

                                <div class="abs top-0 pt-lg-5 end-0 p-sm-relative wow fadeInRight" data-wow-delay="1.5s">
                                    <div class="d-flex">
                                        <i class="fs-60 icofont-google-map id-color"></i>
                                        <div class="ms-3 mb-4">
                                            <h4 class="mb-0">CylinderMargin LDA<br>Ovar, Portugal · 2026</h4>
                                        </div>
                                    </div>
                                </div>

                                <div class="abs w-30 w-sm-100 bottom-0 p-sm-relative wow fadeInRight" data-wow-delay="1.5s">
                                    <p class="op-9">Ecossistema territorial e institucional: Ovar funda, Santa Maria da Feira expande e Aveiro consagra o ciclo com densidade científica e estratégica — sempre com IA inclusiva e regenerativa.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section id="section-about" class="bg-dark section-dark text-light">
            <div class="container">
                <div class="row  gx-5 align-items-center">
                    <div class="col-lg-6">
                          <div class="me-lg-5 pe-lg-5 py-5 my-5">
                              <div class="subtitle wow fadeInUp" data-wow-delay=".2s">1. Enquadramento geral</div>
                              <h2 class="wow fadeInUp" data-wow-delay=".4s">Plataforma portuguesa de inteligência, regeneração, inclusão e ação</h2>
                              <p class="wow fadeInUp" data-wow-delay=".6s">O IRIA SUMMIT PORTUGAL é uma plataforma nacional de encontro, articulação e projeção, concebida para transformar inteligência artificial, inovação aplicada e cooperação multissetorial em impacto concreto sobre o território, as organizações e a sociedade.</p>
                              <p class="wow fadeInUp" data-wow-delay=".65s">Organizado como um ciclo progressivo de três fases, o IRIA liga conhecimento, empresas, instituições, ciência, educação, saúde e decisão estratégica, afirmando um modelo de continuidade que ultrapassa a lógica de um evento isolado.</p>

                              <ul class="ul-check">
                                  <li class="wow fadeInUp" data-wow-delay=".8s">Ovar — origem, validação e ativação fundadora</li>
                                  <li class="wow fadeInUp" data-wow-delay=".9s">Santa Maria da Feira — expansão, competitividade e ecossistema empresarial</li>
                                  <li class="wow fadeInUp" data-wow-delay="1s">Aveiro — consolidação, autoridade, ciência e visão europeia</li>
                              </ul>

                          </div>
                    </div>

                    <div class="col-lg-6">
                        <div class="row g-4">
                            <div class="col-6">
                                <div class="relative overflow-hidden rounded-1 wow scale-in-mask mb-4">
                                    <img src="assets/images/misc/s1.webp" class="img-fluid" alt="">
                                    <div class="gradient-edge-bottom h-50"></div>
                                </div>
                                <div class="col-12 text-center">
                                    <div class="bg-color text-light p-30 rounded-1 wow scale-in-mask">
                                        <div class="de_count">
                                            <h2 class="mb-0"><span class="timer" data-to="3" data-speed="2000"></span></h2>
                                            <div>Cidades anfitriãs</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="spacer-double sm-hide"></div>
                                <div class="col-12 text-center">
                                    <div class="bg-color-2 text-light p-30 rounded-1 wow scale-in-mask">
                                        <div class="de_count">
                                            <h2 class="mb-0"><span class="timer" data-to="4" data-speed="2000"></span></h2>
                                            <div>Dias por edição (modelo)</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="relative overflow-hidden rounded-1 wow scale-in-mask mt-4">
                                    <img src="assets/images/misc/s2.webp" class="img-fluid" alt="">
                                    <div class="gradient-edge-bottom h-50"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        {% include 'partials/marquee-bands-iria.html.twig' %}

        {% include 'partials/section-summit-delivers-iria.html.twig' %}

        <section class="bg-dark section-dark text-light pt-80 relative jarallax" aria-label="section">
            <img src="assets/images/background/2.webp" class="jarallax-img" alt="">
            <div class="gradient-edge-top"></div>
            <div class="gradient-edge-bottom"></div>
            <div class="sw-overlay op-8"></div>
            <div class="container relative z-4">
                <div class="row align-items-center g-5">
                    <div class="col-md-4 order-md-2">
                        <div class="relative w-100 d-inline-block ps-5">
                            <img src="assets/images/misc/ricardo-oficial.png" class="w-100 rounded-1 wow scale-in-mask" alt="Ricardo Pereira">
                        </div>
                    </div>

                    <div class="col-md-8 order-md-1">
                        <div class="subtitle wow fadeInUp mb-2" data-wow-delay=".1s">Visão do Fundador</div>
                        <h3 class="fs-32 mb-4 wow fadeInUp"><span class="d-inline-flex align-items-center justify-content-center bg-color text-white rounded-1 me-3" style="width:48px;height:48px;vertical-align:middle;"><i class="icofont-quote-left fs-28" aria-hidden="true"></i></span>“A inteligência artificial só tem valor estrutural quando reforça capacidades humanas, fortalece instituições, ajuda organizações a operar melhor e contribui para regenerar sistemas sociais, económicos e territoriais.”</h3>

                        <span class="fw-bold">Ricardo Pereira</span>
                        <span class="d-block fs-14 op-7 mt-1">Fundador e Diretor-Geral, CylinderMargin LDA</span>
                        <p class="fs-15 op-8 mt-3 mb-0 wow fadeInUp" data-wow-delay=".3s">Ricardo Pereira é fundador da CylinderMargin LDA e criador do IRIA SUMMIT PORTUGAL. A sua visão cruza inteligência artificial, regeneração, inclusão, desenvolvimento territorial e articulação institucional, com foco na criação de plataformas de impacto real e continuidade estratégica.</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="section-speakers" class="bg-dark section-dark text-light">
            <div class="container">
                <div class="row g-4 justify-content-center">
                    <div class="col-lg-10 relative z-3">
                          <div class="text-center">
                              <div class="subtitle wow fadeInUp" data-wow-delay=".0s">Oradores</div>
                              <h2 class="wow fadeInUp" data-wow-delay=".2s">Oradores e Convidados Estratégicos</h2>
                              <p class="lead wow fadeInUp mb-3">O painel do IRIA SUMMIT PORTUGAL está a ser construído em articulação com parceiros, instituições, empresas, academia e convidados de referência, de forma progressiva e alinhada com a identidade de cada fase do ciclo.</p>
                              <p class="wow fadeInUp op-9 mb-3">Mais do que reunir nomes, o IRIA procura construir um painel com relevância prática, densidade institucional e diversidade de perspetivas, cruzando inteligência artificial, território, inovação, capacitação, ciência, desenvolvimento económico e transformação aplicada.</p>
                              <p class="wow fadeInUp op-9 mb-0">Os primeiros anúncios serão feitos por fase, à medida que as confirmações forem formalizadas.</p>
                          </div>
                    </div>
                </div>

                <div class="row g-4 align-items-stretch mt-3 mt-lg-4">
                    <div class="col-lg-4">
                        <div class="hover relative rounded-1 overflow-hidden wow fadeIn scale-in-mask w-100" style="min-height: 480px;">
                            <img src="assets/images/speakers/painel-principal.webp" class="position-absolute top-0 start-0 w-100 h-100 hover-scale-1-1 op-4" alt="Conferência e painel de oradores" style="object-fit: cover;">
                            <div class="abs w-100 h-100 start-0 top-0 hover-op-1 radial-gradient-color"></div>
                            <div class="abs w-100 start-0 bottom-0 z-3">
                                <div class="bg-blur p-4 m-4 rounded-1 text-light relative z-2">
                                    <h3 class="mb-2 fs-22">Painel Principal</h3>
                                    <p class="mb-0 fs-14 op-9 lh-1-6" style="white-space: normal;">Intervenções centrais com líderes, especialistas, decisores e convidados com contributo estratégico para o posicionamento do summit.</p>
                                </div>
                                <div class="gradient-edge-bottom h-100 op-8"></div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="hover relative rounded-1 overflow-hidden wow fadeIn scale-in-mask w-100" style="min-height: 480px;">
                            <img src="assets/images/speakers/curadoria-fases.webp" class="position-absolute top-0 start-0 w-100 h-100 hover-scale-1-1 op-4" alt="Cidades e território — curadoria por fase" style="object-fit: cover;">
                            <div class="abs w-100 h-100 start-0 top-0 hover-op-1 radial-gradient-color"></div>
                            <div class="abs w-100 start-0 bottom-0 z-3">
                                <div class="bg-blur p-4 m-4 rounded-1 text-light relative z-2">
                                    <h3 class="mb-2 fs-22">Curadoria por Fase</h3>
                                    <p class="mb-0 fs-14 op-9 lh-1-6" style="white-space: normal;">Cada cidade contará com convidados alinhados com o seu eixo temático: ativação em Ovar, expansão em Santa Maria da Feira e consolidação em Aveiro.</p>
                                </div>
                                <div class="gradient-edge-bottom h-100 op-8"></div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="hover relative rounded-1 overflow-hidden wow fadeIn scale-in-mask w-100" style="min-height: 480px;">
                            <img src="assets/images/speakers/anuncios-atualizacao.webp" class="position-absolute top-0 start-0 w-100 h-100 hover-scale-1-1 op-4" alt="Planeamento e calendário de anúncios" style="object-fit: cover;">
                            <div class="abs w-100 h-100 start-0 top-0 hover-op-1 radial-gradient-color"></div>
                            <div class="abs w-100 start-0 bottom-0 z-3">
                                <div class="bg-blur p-4 m-4 rounded-1 text-light relative z-2">
                                    <h3 class="mb-2 fs-22">Anúncios em Atualização</h3>
                                    <p class="mb-0 fs-14 op-9 lh-1-6" style="white-space: normal;">A programação de oradores e convidados será divulgada progressivamente, acompanhando a consolidação das parcerias e das confirmações institucionais.</p>
                                </div>
                                <div class="gradient-edge-bottom h-100 op-8"></div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <section class="bg-dark section-dark pt-80 relative jarallax" aria-label="section">
            <img src="assets/images/background/1.webp" class="jarallax-img" alt="">
            <div class="gradient-edge-top"></div>
            <div class="gradient-edge-bottom"></div>
            <div class="sw-overlay op-8"></div>
            <div class="container">
                <div class="row g-4">

                    <div class="col-md-12 wow fadeInUp">
                        <div class="owl-6 no-alpha owl-carousel owl-theme wow mask-right">
                            <img src="assets/images/logo-light/1.webp" class="w-100 px-4" alt="">
                            <img src="assets/images/logo-light/2.webp" class="w-100 px-4" alt="">
                            <img src="assets/images/logo-light/3.webp" class="w-100 px-4" alt="">
                            <img src="assets/images/logo-light/4.webp" class="w-100 px-4" alt="">
                            <img src="assets/images/logo-light/5.webp" class="w-100 px-4" alt="">
                            <img src="assets/images/logo-light/6.webp" class="w-100 px-4" alt="">
                            <img src="assets/images/logo-light/7.webp" class="w-100 px-4" alt="">
                            <img src="assets/images/logo-light/8.webp" class="w-100 px-4" alt="">
                            <img src="assets/images/logo-light/9.webp" class="w-100 px-4" alt="">
                            <img src="assets/images/logo-light/10.webp" class="w-100 px-4" alt="">
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {% include 'partials/section-phase-ovar-iria.html.twig' %}

        {% include 'partials/section-phase-feira-iria.html.twig' %}

        {% include 'partials/section-phase-aveiro-iria.html.twig' %}

        {% include 'partials/section-schedule-iria.html.twig' %}

        {% include 'partials/section-themes-iria.html.twig' %}

        {% include 'partials/section-tickets-iria.html.twig' %}

        {% include 'partials/section-partners-iria.html.twig' %}
        {% include 'partials/section-institutional-iria.html.twig' %}

        {% include 'partials/section-faq-iria.html.twig' %}

        {% include 'partials/section-contact-emails-iria.html.twig' with { edition: 'portugal' } %}

        {% include 'partials/section-newsletter-iria.html.twig' %}

    </div>

{% endblock %}

{% block page_scripts %}
    <script src="assets/js/countdown-custom.js"></script>
    <script src="assets/js/custom-marquee.js"></script>
{% endblock %}


