{% extends 'partials/layouts/master.html.twig' %}

{% block page_contents %}

        <section id="section-hero" class="section-dark no-top no-bottom text-light jarallax relative mh-800" data-video-src="mp4:assets/video/1.mp4">
            <div class="gradient-edge-top op-6 h-50 color"></div>
            <div class="gradient-edge-bottom"></div>
            <div class="sw-overlay op-8"></div>
            <div class="abs abs-centered z-2 w-100">
                <div class="container wow scaleIn" data-wow-duration="3s">
                    <div class="row g-4 justify-content-between align-items-center">
                        <div class="col-lg-6">
                            <div>
                                <div class="d-block d-md-flex mb-2">
                                    <div class="d-flex justify-content-center align-items-center me-4">
                                        <i class="fa fa-calendar id-color me-3"></i>
                                        <h4 class="mb-0">Ciclo 2026 · Ovar · Feira · Aveiro</h4>
                                    </div>

                                    <div class="d-flex justify-content-center align-items-center me-4">
                                        <i class="fa fa-location-pin id-color me-3"></i>
                                        <h4 class="mb-0">1.ª fase: 18–19 jun · Ovar</h4>
                                    </div>
                                </div>
                            </div>
                            <div class="subtitle mb-2">Inteligência · Regeneração · Inclusão · Ação</div>
                            <h1 class="fs-120 text-uppercase fs-sm-12vw mb-2 lh-1">IRIA SUMMIT PORTUGAL 2026</h1>
                            <p class="fs-15 op-8 mb-3">Contagem para a primeira prova pública do ecossistema — junto de parceiros, território e equipas que constroem o percurso.</p>
                            <div class="spacer-single"></div>
                            <a class="btn-main mx-2 fx-slide" href="#section-tickets"><span>Bilhetes</span></a>
                            <a class="btn-main btn-line mx-2 fx-slide" href="#section-schedule"><span>Programa-tipo</span></a>
                        </div>

                        <div class="col-lg-4 text-lg-end">
                            <p class="op-9">
                                O ciclo abre em Ovar, reforça redes em Santa Maria da Feira e projeta autoridade em Aveiro — três escalas, uma narrativa comum de maturação e impacto.
                            </p>

                            <div class="countdown-s2">
                                <div id="defaultCountdown"></div>
                            </div> 
                        </div>
                    </div>
                </div>
            </div>

        </section>

        <section id="section-about" class="bg-dark section-dark text-light">
            <div class="container">
                <div class="row  gx-5 align-items-center justify-content-between">
                    <div class="col-lg-6">
                          <div class="me-lg-5 pe-lg-5 py-5 my-5">
                              <div class="subtitle wow fadeInUp" data-wow-delay=".2s">1. Enquadramento geral</div>
                              <h2 class="wow fadeInUp" data-wow-delay=".4s">Plataforma portuguesa com vocação de continuidade</h2>
                              <p class="wow fadeInUp" data-wow-delay=".6s">O IRIA SUMMIT PORTUGAL é uma plataforma de encontro, articulação e aplicação prática da inteligência artificial numa perspetiva inclusiva, regenerativa, territorial e estrategicamente orientada. Não se limita à lógica de um congresso convencional: liga tecnologia, governação, saúde, educação, empresas, inovação aplicada e desenvolvimento humano.</p>

                              <ul class="ul-check">
                                  <li class="wow fadeInUp" data-wow-delay=".8s">Ovar — origem, validação e legitimidade inicial</li>
                                  <li class="wow fadeInUp" data-wow-delay=".9s">Santa Maria da Feira — consolidação e expansão regional</li>
                                  <li class="wow fadeInUp" data-wow-delay="1s">Aveiro — projeção, autoridade e escala superior</li>
                              </ul>

                          </div>
                    </div>

                    <div class="col-lg-5">
                        <div class="wow scaleIn">
                            <img src="assets/images/misc/c1.webp" class="w-100 rotate-animation" alt="">
                        </div>
                    </div>

                </div>
            </div>
        </section>

        {% include 'partials/marquee-bands-iria.html.twig' %}

        {% include 'partials/section-summit-delivers-iria.html.twig' %}

        <section class="bg-dark section-dark text-light pt-80 relative jarallax" aria-label="section">
            <img src="assets/images/background/2.webp" class="jarallax-img" alt="">
            <div class="gradient-edge-top"></div>
            <div class="gradient-edge-bottom"></div>
            <div class="sw-overlay op-8"></div>
            <div class="container relative z-4">
                <div class="row align-items-center g-5">
                    <div class="col-md-4">
                        <div class="relative w-100 d-inline-block pe-5">
