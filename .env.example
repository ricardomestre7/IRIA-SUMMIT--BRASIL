# IASUMMIT — Environment Variables
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/iasummit

# API
API_PORT=3000
NODE_ENV=development

# cyntreon-core integration
CYNTREON_CORE_URL=http://localhost:4000
CYNTREON_SERVICE_KEY=sk_...

# AI Engine
AI_MODEL_PATH=./models/regenerative_v1
AI_INFERENCE_TIMEOUT=5000
